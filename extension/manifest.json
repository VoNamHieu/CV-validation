{
  "manifest_version": 3,
  "name": "JobFit AI — Auto Apply",
  "version": "2.0.0",
  "description": "AI Agent tự động ứng tuyển trên BẤT KỲ job site nào với CV đã optimize từ JobFit AI",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "https://*.vercel.app/*"
      ],
      "js": [
        "content-webapp.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*/*"
      ],
      "exclude_matches": [
        "https://*.google.com/*",
        "https://*.youtube.com/*",
        "https://*.facebook.com/*",
        "https://*.vercel.app/*"
      ],
      "js": [
        "utils.js",
        "content-agent.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}