# Environment variables
GEMINI_API_KEY=your_gemini_api_key_here
CORS_ORIGINS=http://localhost:3000,https://your-vercel-domain.vercel.app

# Debug-capture dev tool (extension → /debug/capture). Leave UNSET to disable
# the endpoint entirely (it 503s). Set to a long random secret to enable, then
# paste the same value into the extension's Settings → Debug token field.
# DEBUG_CAPTURE_TOKEN=change-me-to-a-long-random-secret
