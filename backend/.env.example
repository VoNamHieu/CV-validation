# Environment variables
GEMINI_API_KEY=your_gemini_api_key_here
CORS_ORIGINS=http://localhost:3000,https://your-vercel-domain.vercel.app

# Per-IP rate limit (in-memory). Loopback/private clients (local dev) are always
# exempt; these only bound public traffic. 30/min is tight for a real SPA session
# — raise if legit users see "Too many requests".
# RATE_LIMIT_MAX=120
# RATE_LIMIT_WINDOW=60

# Debug-capture dev tool (extension → /debug/capture). Leave UNSET to disable
# the endpoint entirely (it 503s). Set to a long random secret to enable, then
# paste the same value into the extension's Settings → Debug token field.
# DEBUG_CAPTURE_TOKEN=change-me-to-a-long-random-secret

# ── Supabase Postgres (direct, service-role DSN) ──
# Use the pooler/session connection string (port 5432). URL-encode special
# chars in the password (# → %23, @ → %40, ! → %21).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# DB_POOL_MAX=10

# Supabase Auth — verify JWTs on /me/* endpoints.
# This project signs tokens with ES256 (asymmetric), so the backend verifies
# against the PUBLIC JWKS — no secret to copy. Just set the project URL:
# SUPABASE_URL=https://<project-ref>.supabase.co
# (Legacy HS256 projects instead set SUPABASE_JWT_SECRET=... — fallback path.)
# When NEITHER is set AND ALLOW_DEV_AUTH=1 is also set, the backend falls back
# to trusting the X-User-Id header as-is. Local dev only — never set this in
# prod (the service-role DSN bypasses RLS, so that header would otherwise be
# the entire security boundary if the two vars above were ever unset by accident).
# ALLOW_DEV_AUTH=1

# Admin tooling (/admin/* — e.g. granting credits). Comma-separated allowlist of
# emails permitted to use it; matched against the caller's profiles.email.
# Empty/unset → the admin surface is fully closed (403).
# ADMIN_EMAILS=charles@rezona.ai

# Where /career/search pulls its candidate pool from:
#   featured (default) = in-memory crawl cache only (unchanged behaviour)
#   db                 = the Postgres jobs/companies store only
#   both               = merge DB jobs into the featured pool (deduped by url)
# CATALOG_SOURCE=featured

# Shared secret for server-initiated credit refunds (POST /credits/refund).
# Must match CREDITS_INTERNAL_KEY on the Next.js server (Vercel). Unset =
# refunds disabled (fail closed); spends are unaffected.
CREDITS_INTERNAL_KEY=

# ── Telegram monitoring via Supabase Database Webhooks ──
# Flow: Supabase fires a webhook on INSERT into public.profiles (new user) and
# public.incidents (error) → POST /webhooks/supabase on this backend → Telegram.
#
# 1. Telegram bot (both unset = alerts are a silent no-op):
#    @BotFather → /newbot → token; DM the bot / add to a group, send a message,
#    then read chat.id from https://api.telegram.org/bot<TOKEN>/getUpdates
#    (group id is negative, e.g. -1001234567890).
# TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token...
# TELEGRAM_CHAT_ID=-1001234567890
#
# 2. Shared secret gating POST /webhooks/supabase. Unset = the webhook endpoint
#    is disabled (503). Put the SAME value in each Supabase webhook as a custom
#    HTTP header:  X-Webhook-Secret: <this value>
# SUPABASE_WEBHOOK_SECRET=change-me-to-a-long-random-secret
